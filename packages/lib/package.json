{
  "name": "@kurone-kito/pwt-lib",
  "version": "0.1.0",
  "private": true,
  "description": "The boilerplate of the Node.js library",
  "keywords": [
    "library",
    "boilerplate",
    "template"
  ],
  "homepage": "https://github.com/kurone-kito/pnpm-workspace-template#readme",
  "bugs": "https://github.com/kurone-kito/pnpm-workspace-template/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurone-kito/pnpm-workspace-template.git",
    "directory": "packages/lib"
  },
  "license": "MIT",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "exports": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" coverage dist LICENSE node_modules/.cache",
    "dev": "vite build --watch",
    "prebuild": "cpy --flat ../../LICENSE .",
    "prepack": "pnpm run clean && pnpm run build",
    "test": "pnpm run \"/test:.+/\"",
    "test:ts": "tsc -p tsconfig.test.json --noEmit",
    "test:vitest": "vitest run --coverage"
  },
  "devDependencies": {
    "@kurone-kito/typescript-config": "^0.22.0-alpha.4",
    "@kurone-kito/vite-lib-config": "^0.22.0-alpha.4",
    "@vitest/coverage-v8": "^4.0.18",
    "cpy-cli": "^6.0.0",
    "rimraf": "^6.1.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "^20.18 || ^22 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
