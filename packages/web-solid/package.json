{
  "name": "@kurone-kito/pwt-web-solid",
  "version": "0.1.0",
  "private": true,
  "description": "The SolidJS web app boilerplate",
  "keywords": [
    "web",
    "solid.js",
    "boilerplate",
    "template"
  ],
  "homepage": "https://github.com/kurone-kito/pnpm-workspace-template#readme",
  "bugs": "https://github.com/kurone-kito/pnpm-workspace-template/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurone-kito/pnpm-workspace-template.git",
    "directory": "packages/web-solid"
  },
  "license": "MIT",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "files": [
    ".output",
    ".vinxi"
  ],
  "scripts": {
    "build": "vinxi build",
    "clean": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" .output .vinxi coverage LICENSE node_modules/.cache",
    "dev": "vinxi dev",
    "prebuild": "cpy --flat ../../LICENSE .",
    "prepack": "pnpm run clean && pnpm run build",
    "prepare": "playwright install --with-deps",
    "test": "pnpm run \"/test:.+/\"",
    "test:e2e": "playwright test",
    "test:ts": "tsc -p tsconfig.test.json --noEmit",
    "test:vitest": "vitest run --coverage"
  },
  "dependencies": {
    "@kurone-kito/pwt-lib": "workspace:^",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@solidjs/start": "^1.2.1",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@kurone-kito/typescript-config": "^0.22.0-alpha.4",
    "@kurone-kito/vite-lib-config": "^0.22.0-alpha.4",
    "@kurone-kito/vrc-icons-tw": "^0.15.0",
    "@playwright/test": "^1.58.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.0.10",
    "@vitest/coverage-v8": "^4.0.18",
    "cpy-cli": "^6.0.0",
    "daisyui": "^5.5.14",
    "jsdom": "^27.4.0",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4.1.18",
    "tailwindcss-safe-area": "^1.3.0",
    "type-fest": "^5.4.1",
    "typescript": "~5.9.3",
    "vinxi": "^0.5.11",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "^20.18 || ^22 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
